# Django Settings
DEBUG=0
SECRET_KEY=generate-a-secure-secret-key-here
ALLOWED_HOSTS=yourdomain.com,your-vps-ip

# Database (PostgreSQL)
POSTGRES_DB=findsalon_db
POSTGRES_USER=findsalon_user
POSTGRES_PASSWORD=secure-db-password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis & Celery
CELERY_BROKER_URL=redis://redis:6379/0

# Firebase
FIREBASE_SERVICE_ACCOUNT_PATH=/app/firebase-service-account.json
